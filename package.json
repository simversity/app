{
  "name": "simversity",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rsbuild build",
    "check": "biome check --write",
    "dev": "trap 'kill 0' INT; bun --watch server/index.ts & rsbuild dev --open & wait",
    "dev:ui": "rsbuild dev --open",
    "dev:api": "bun --watch server/index.ts",
    "format": "biome format --write",
    "lint": "biome check",
    "type-check": "tsc --noEmit && tsc --noEmit --project tsconfig.server.json && tsc --noEmit --project tsconfig.test.json",
    "preview": "rsbuild preview",
    "db:push": "bun drizzle-kit push",
    "db:generate": "bun drizzle-kit generate",
    "db:migrate": "bun server/db/migrate.ts",
    "db:seed": "bun server/db/seed.ts",
    "db:studio": "bun drizzle-kit studio",
    "start": "bun server/index.ts",
    "promote-admin": "bun server/scripts/promote-admin.ts",
    "test:frontend": "bun test --preload ./src/components/__tests__/setup-dom.ts src/",
    "test:server": "bun test server/lib/ server/ai/ server/db/",
    "test:routes": "bun test --preload ./server/__tests__/preload.ts server/routes/",
    "test:unit": "bun run test:frontend && bun run test:server && bun run test:routes",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=coverage --preload ./src/components/__tests__/setup-dom.ts src/ && bun test --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=coverage server/lib/ server/ai/ server/db/ && bun test --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=coverage --preload ./server/__tests__/preload.ts server/routes/",
    "test:e2e": "bunx playwright test",
    "test:ui": "bunx playwright test --ui",
    "test": "bun run test:unit && bun run test:e2e",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@scalar/hono-api-reference": "^0.9.47",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.159.10",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.11.9",
    "js-tiktoken": "^1.0.21",
    "lucide-react": "^0.564.0",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "openai": "^6.22.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "resend": "^6.9.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "use-stick-to-bottom": "^1.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@playwright/test": "^1.58.2",
    "@rsbuild/core": "^1.7.1",
    "@rsbuild/plugin-react": "^1.4.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/router-plugin": "^1.159.12",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.9",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "happy-dom": "^20.7.0",
    "lefthook": "^1.11.13",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
