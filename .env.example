# Database (defaults to sqlite.db locally, /data/sqlite.db on Railway with volume)
DATABASE_URL=sqlite.db

# Server port (defaults to 3001)
PORT=3001

# App URL (used for CORS and auth trusted origins)
# On Railway: set to https://your-app.up.railway.app or your custom domain
APP_URL=http://localhost:3000

# Authentication
BETTER_AUTH_SECRET=CHANGE_ME_run_openssl_rand_-hex_32
# In production with single-origin serving, BETTER_AUTH_URL = APP_URL (auto-detected)
BETTER_AUTH_URL=http://localhost:3001

# NEAR AI Cloud (https://cloud.near.ai/api-keys)
NEARAI_API_KEY=
NEARAI_MODEL=deepseek-ai/DeepSeek-V3.1
NEARAI_MAX_TOKENS=500

# Admin invite code (optional — leave blank to hide the admin signup field)
ADMIN_INVITE_CODE=

# Email (Resend — https://resend.com/api-keys)
# Optional in dev (emails logged to console). Required in production.
RESEND_API_KEY=
EMAIL_FROM=Simversity <noreply@yourdomain.com>

# Trust proxy headers (x-forwarded-for) for client IP extraction
# Set to 1 when running behind a reverse proxy (e.g. Railway, nginx)
TRUST_PROXY=

# Testing (optional)
# WARNING: TEST_MODE=1 raises rate limits significantly — never enable in production.
TEST_MODE=
# Override the test user password created by bun run db:seed
TEST_USER_PASSWORD=

# Mock AI responses (optional)
# Set to 1 to return canned AI responses instead of calling NEAR AI.
# Useful for local development and CI without an API key.
MOCK_AI=
# Port for the mock AI server (defaults to 4100)
MOCK_AI_PORT=

# Model allowlist (optional — comma-separated model IDs)
# When set, only listed models can be selected by users.
MODEL_ALLOWLIST=

# Per-user daily AI message limit (optional — defaults to unlimited)
DAILY_MESSAGE_LIMIT=
